<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "%ctx%owner::Id|EventRegistrationMode=Resolve%/ctx%.onAttached",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "const element = TcHmi.Controls.get('desktop-grid-machinecontrol');",
          "const button = TcHmi.Controls.get('desktop-btn-showhide');",
          "const grid = element.getElement()[0];",
          "",
          "let isDragging = false;",
          "let hasMoved = false;",
          "let offsetY = 0;",
          "let startY = 0;",
          "let pointerId = null;",
          "let dragThreshold = 5;",
          "",
          "grid.addEventListener('dragstart', function(e) {",
          "  e.preventDefault();",
          "});",
          "",
          "grid.style.userSelect = 'none';",
          "grid.style.webkitUserSelect = 'none';",
          "",
          "button.getElement()[0].addEventListener('pointerdown', function(e) {",
          "  isDragging = true;",
          "  hasMoved = false;",
          "  pointerId = e.pointerId;",
          "",
          "  startY = e.clientY;",
          "",
          "  let rect = grid.getBoundingClientRect();",
          "  offsetY = e.clientY - rect.top;",
          "});",
          "",
          "// Use document-level pointermove to catch movement outside element",
          "document.addEventListener('pointermove', function(e) {",
          "  let isLocked = new TcHmi.Symbol('%i%machineControlLocked%/i%').read();",
          "  if (isLocked) return;",
          "  if (!isDragging || e.pointerId !== pointerId) return;",
          "",
          "  let deltaY = Math.abs(e.clientY - startY);",
          "",
          "  if (deltaY > dragThreshold) {",
          "      if (!hasMoved) {",
          "          // First time crossing threshold - capture pointer for touch",
          "          if (e.pointerType === 'touch') {",
          "              grid.setPointerCapture(e.pointerId);",
          "          }",
          "          hasMoved = true;",
          "      }",
          "",
          "      e.preventDefault();",
          "      e.stopPropagation();",
          "",
          "      let newTop = e.clientY - offsetY;",
          "",
          "      element.setTop(newTop);",
          "  }",
          "});",
          "",
          "document.addEventListener('pointerup', function(e) {",
          "  if (!isDragging || e.pointerId !== pointerId) return;",
          "",
          "  if (hasMoved) {",
          "      e.preventDefault();",
          "      e.stopPropagation();",
          "      e.stopImmediatePropagation();",
          "",
          "      if (e.pointerType === 'touch' && grid.hasPointerCapture(e.pointerId)) {",
          "          grid.releasePointerCapture(e.pointerId);",
          "      }",
          "  }",
          "",
          "  isDragging = false;",
          "  pointerId = null;",
          "});",
          "",
          "grid.addEventListener('pointercancel', function(e) {",
          "  isDragging = false;",
          "  hasMoved = false;",
          "  pointerId = null;",
          "});",
          "",
          "grid.addEventListener('click', function(e) {                    \t",
          "  if (hasMoved) {",
          "      e.preventDefault();",
          "      e.stopPropagation();",
          "      e.stopImmediatePropagation();",
          "",
          "      setTimeout(function() {",
          "          hasMoved = false;",
          "      }, 10);",
          "",
          "      return false;",
          "  }",
          "}, true);"
        ],
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  },
  {
    "event": "%ctx%owner::Id|EventRegistrationMode=Resolve%/ctx%.onResized",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "// sets CSS variable with current columns width of pml control",
          "let element = document.getElementById('desktop-grid-machinecontrol');",
          "",
          "TcHmi.Symbol.readEx2('%ctrl%desktop-grid-machinecontrol::ColumnOptions[1]::width%/ctrl%', function(data) {",
          "\telement.style.setProperty('--pmlcontrol-column-width', data.value + 'px');",
          "});"
        ],
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>
</div>




