<div id="settings-btn-restartserver" data-tchmi-type="TcHmi.Controls.TcHmiExtendedControls.ConfirmationButton" data-tchmi-text="%l%RestartHMIServer%/l%" data-tchmi-word-wrap="true" data-tchmi-confirmation-message="%l%RestartHMIServerConfirmation%/l%" data-tchmi-zindex="1" data-tchmi-grid-row-index="0" data-tchmi-grid-column-index="0" data-tchmi-width="50" data-tchmi-height="100" data-tchmi-height-unit="%">
<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">[
  {
    "event": "%ctx%owner::Id|EventRegistrationMode=Resolve%/ctx%.onConfirmed",
    "actions": [
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%s%Restart%/s%",
        "value": {
          "objectType": "StaticValue",
          "valueType": "tchmi:general#/definitions/String",
          "value": null
        },
        "asyncWait": true
      },
      {
        "objectType": "JavaScript",
        "active": false,
        "sourceLines": [
          "// Request object.",
          "/** @type {TcHmi.Server.IMessage} */",
          "var request = {",
          "    \"commands\": [",
          "        {",
          "            \"commandOptions\": [",
          "                \"SendErrorMessage\",",
          "                \"SendWriteValue\"",
          "            ],",
          "            \"symbol\": \"Restart\"",
          "        }",
          "    ],",
          "    \"requestType\": \"ReadWrite\"",
          "};",
          "",
          "// Send request to TwinCAT HMI Server.",
          "TcHmi.Server.requestEx(request, { timeout: 2000 }, function(data){",
          "    // Callback handling.",
          "    if(data.error !== TcHmi.Errors.NONE){",
          "        // Handle TcHmi.Server class level error here.",
          "        console.log(data.error)",
          "        return;",
          "    }",
          "    var response = data.response;",
          "    if (!response || response.error !== undefined) {",
          "        // Handle TwinCAT HMI Server response level error here.",
          "        console.log(response)",
          "        return;",
          "    }",
          "    var commands = response.commands;",
          "    if(commands === undefined){",
          "        console.log(commands)",
          "        return;",
          "    }",
          "    for(var i = 0, ii = commands.length; i < ii; i++){",
          "        var command = commands[i];",
          "        if(command === undefined){",
          "        \tconsole.log(command)",
          "            return;",
          "        }",
          "        if(command.error !== undefined){",
          "            // Handle TwinCAT HMI Server command level error here.",
          "        \tconsole.log(command.error)",
          "            return;",
          "        }",
          "        // Handle result...",
          "        console.log(command)",
          "        TcHmi.Log.debugEx(command.symbol, ':', command.readValue);",
          "    }",
          "});"
        ],
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]</script>

<script data-tchmi-target-attribute="data-tchmi-text-padding" type="application/json">
