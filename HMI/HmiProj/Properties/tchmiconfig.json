                    {
                      "objectType": "StaticValue",
                      "valueType": "tchmi:general#/definitions/Boolean",
                      "value": true
                    },
                    {
                      "objectType": "StaticValue",
                      "valueType": "tchmi:framework#/definitions/ThemeName",
                      "value": "Base"
                    },
                    {
                      "objectType": "StaticValue",
                      "valueType": "tchmi:framework#/definitions/ThemeName",
                      "value": "Base-Dark"
                    }
                  ],
                  "asyncWait": true
                }
              ]
            }
          ],
          "asyncWait": true
        },
        {
          "objectType": "Condition",
          "active": true,
          "parts": [
            {
              "if": [
                {
                  "compare1": {
                    "objectType": "Symbol",
                    "valueType": "tchmi:general#/definitions/Boolean",
