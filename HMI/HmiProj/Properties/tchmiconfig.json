                  "fn": "TcHmi.Functions.TcHmiExtendedControls.UseSystemTheme",
                  "fnParams": [
                    {
                      "objectType": "StaticValue",
                      "valueType": "tchmi:general#/definitions/Boolean",
                      "value": false
