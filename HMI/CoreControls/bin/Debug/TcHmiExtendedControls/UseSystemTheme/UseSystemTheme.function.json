        "description": "Name of default light theme.",
        "defaultValue": "Base",
        "required": true,
        "bindable": true
      },
      {
        "name": "defaultDarkTheme",
        "displayName": "DefaultDarkTheme",
        "type": "tchmi:framework#/definitions/ThemeName",
