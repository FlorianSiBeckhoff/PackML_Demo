        "displayName": "ColorProperty",
        "type": "tchmi:framework#/definitions/ControlPropertyName",
        "refTo": "control",
        "description": "The color property of the control. Could be background color, fill color, border color, text color, etc.",
        "defaultValue": null,
        "required": true,
        "bindable": true
      },
      {
        "name": "color",
        "displayName": "Color",
        "type": "tchmi:framework#/definitions/SolidColor",
        "description": "The color to blink.",
        "defaultValue": null,
        "required": true,
        "bindable": true
      },
      {
        "name": "blinkRate",
        "displayName": "BlinkRate",
        "type": "tchmi:general#/definitions/Number",
