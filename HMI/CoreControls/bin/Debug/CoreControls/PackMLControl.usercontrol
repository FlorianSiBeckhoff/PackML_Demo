<div id="{PkgId}.pmlcontrol-img-infobtn" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiImage" data-tchmi-left="10" data-tchmi-left-unit="px" data-tchmi-top="5" data-tchmi-top-unit="px" data-tchmi-width="%ctrl%{PkgId}.pmlcontrol-img-infobtn::RenderedHeight%/ctrl%" data-tchmi-width-unit="px" data-tchmi-bottom="5" data-tchmi-src="{PkgBasePath}/Images/Icons/info.svg" data-tchmi-min-width="20" data-tchmi-min-height="20">

