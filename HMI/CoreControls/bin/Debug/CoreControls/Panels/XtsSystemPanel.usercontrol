    <div id="{PkgId}.xtssystempanel-popup-details" data-tchmi-type="TcHmi.Controls.System.TcHmiPopup" data-tchmi-height="450" data-tchmi-height-unit="px" data-tchmi-left="210" data-tchmi-left-unit="px" data-tchmi-top="10" data-tchmi-top-unit="px" data-tchmi-width="820" data-tchmi-width-unit="px" data-tchmi-header-text="%pp%data::Name%/pp%" data-tchmi-restore-bounds="False" data-tchmi-modal="True">
        <script data-tchmi-target-attribute="data-tchmi-target-file" type="application/json">
            {
              "path": "{PkgBasePath}/CoreControls/Popups/XtsSystem.usercontrol",
              "attributes": {
                "data-tchmi-data": "%pp%data%/pp%"
              }
            }
        </script>
    </div>

    <script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "%ctx%owner::Id|EventRegistrationMode=Resolve%/ctx%.onPressed",
    "actions": [
      {
        "objectType": "Condition",
        "active": true,
        "parts": [
          {
            "if": [
              {
                "compare1": {
                  "objectType": "Symbol",
                  "valueType": "tchmi:general#/definitions/BOOL",
                  "symbolExpression": "%pp%data::HmiEnabled%/pp%"
                },
                "compare2": {
                  "objectType": "StaticValue",
                  "valueType": "tchmi:general#/definitions/BOOL",
                  "value": true
                },
                "compareOperator": "==",
                "logic": null
              }
            ],
            "then": [
              {
                "objectType": "ControlApiFunction",
                "active": true,
                "control": "{PkgId}.xtssystempanel-popup-details",
                "fn": "open",
                "asyncWait": true
              }
            ]
          },
          {
            "else": []
          }
        ],
        "asyncWait": true
      }
    ]
  }
]
</script>

</div>
