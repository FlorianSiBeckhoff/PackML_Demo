    </Method>
    <Method Name="Starting" Id="{6cee2754-c5ab-4342-903e-29a875c97e85}" FolderPath="States\">
      <Declaration><![CDATA[METHOD Starting : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Starting := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="StateSelect" Id="{13881525-b521-4102-aead-d8a7122bf0de}" FolderPath="States\">
      <Declaration><![CDATA[METHOD PRIVATE StateSelect
VAR_INST
	ClearingTon : TON;
	LastState	: DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _CurrentState = E_PMLState.Undefined AND _CurrentMode <> 0 THEN
	StateCommand := E_PMLCommand.Abort;
END_IF

StateMachine(eMode			  := TO_DINT(_CurrentMode),
			 eCommand		  := StateCommand,
			 stSubUnitInfoRef :=,
			 stOptions		  :=,
			 eState			  => _CurrentState,
			 sState			  =>,
			 bError			  =>,
			 nErrorID		  =>);

IF LastState <> _CurrentState THEN
	SequenceState := 0;
	LastState	  := _CurrentState;
END_IF

CASE _CurrentState OF
	E_PMLState.Undefined:
		;

	E_PMLState.Clearing:
		ClearingTon(IN := TRUE, PT := CLEARING_TIMEOUT);
		IF Clearing() THEN
			ClearingTon(IN := FALSE);
			Statemachine.M_StateComplete();
		END_IF

		IF ClearingTon.Q THEN
			ClearingTon(IN := FALSE);
			Trace.LogMessage('Clearing Timeout exeeded! - ', _Name);
			ChangeState(E_PMLCommand.Abort);
		END_IF

	E_PMLState.Stopped:
		Stopped();

	E_PMLState.Starting:
		IF Starting() THEN
			Statemachine.M_StateComplete();
		END_IF

	E_PMLState.Idle:
		Idle();

	E_PMLState.Suspended:
		Suspended();

	E_PMLState.Execute:
		Execute();

	E_PMLState.Stopping:
		IF Stopping() THEN
			Statemachine.M_StateComplete();
		END_IF

	E_PMLState.Aborting:
		IF Aborting() THEN
			Statemachine.M_StateComplete();
		END_IF

	E_PMLState.Aborted:
		Aborted();

	E_PMLState.Holding:
		IF Holding() THEN
			Statemachine.M_StateComplete();
		END_IF

	E_PMLState.Held:
		Held();

	E_PMLState.Unholding:
		IF Unholding() THEN
			Statemachine.M_StateComplete();
		END_IF

	E_PMLState.Suspending:
		IF Suspending() THEN
			Statemachine.M_StateComplete();
		END_IF

	E_PMLState.Unsuspending:
		IF Unsuspending() THEN
			Statemachine.M_StateComplete();
		END_IF

	E_PMLState.Resetting:
		IF Resetting() THEN
			Statemachine.M_StateComplete();
		END_IF

	E_PMLState.Completing:
		IF Completing() THEN
			Statemachine.M_StateComplete();
		END_IF

	E_PMLState.Completed:
		Completed();
END_CASE]]></ST>
      </Implementation>
    </Method>
