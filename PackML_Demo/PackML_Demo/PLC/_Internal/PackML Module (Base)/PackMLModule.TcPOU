    <Method Name="Aborted" Id="{51e43f5d-fd8d-494c-8a5f-ea0bc5c40c2a}" FolderPath="States\">
      <Declaration><![CDATA[METHOD Aborted : BOOL;]]></Declaration>
      <Implementation>
        <ST><![CDATA[Aborted := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Aborting" Id="{c4250865-8cbe-4aac-bcb8-82d7f21aeaa5}" FolderPath="States\">
      <Declaration><![CDATA[METHOD Aborting : BOOL]]></Declaration>
