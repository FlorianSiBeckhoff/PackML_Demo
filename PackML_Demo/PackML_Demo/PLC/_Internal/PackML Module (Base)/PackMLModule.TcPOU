    <Method Name="CyclicLogic" Id="{216b4710-59af-4382-82b8-ab4bd823dd52}">
      <Declaration><![CDATA[METHOD CyclicLogic
]]></Declaration>
      <Implementation>
        <ST><![CDATA[ModeSelect();
StateSelect();]]></ST>
