    <Method Name="ModeSelect" Id="{21c9f9ba-084f-41c9-8225-a8d17e634f5b}" FolderPath="Mode\">
      <Declaration><![CDATA[METHOD PRIVATE ModeSelect
VAR_INST
	LastModeCommand		: DINT;
	ModeChangeRequested : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _CurrentMode = 0 THEN
	ModeChangeRequested := TRUE;
	ModeCommand			:= E_PMLProtectedUnitMode.Production;
	LastModeCommand		:= ModeCommand;
ELSIF ModeCommand <> LastModeCommand THEN
	ModeChangeRequested := TRUE;
	LastModeCommand		:= ModeCommand;
END_IF

IF ModeChangeRequested THEN
	{warning disable C0196}
	ModeManager(bExecute	 := TRUE,
				eModeCommand := ModeCommand,
				eState		 := _CurrentState,
				eModeStatus	 => _CurrentMode);

	IF ModeManager.bDone THEN
		ModeManager(bExecute := FALSE);
		ModeChangeRequested := FALSE;
	ELSIF ModeManager.bError THEN
		IF ModeManager.nErrorId = 1 THEN
			Trace.LogMessage('PackML Mode Controller', 'Requested mode is not defined or Mode change is disabled in this PackML state!');
		ELSE
			Trace.LogMessage('PackML Mode Controller', 'Mode change error, check PackML configuration!');
		END_IF

		ModeManager(bExecute := FALSE);
		ChangeState(TO_UDINT(E_PMLCommand.Abort));
		ModeCommand			:= E_PMLProtectedUnitMode.Production;
		ModeChangeRequested := FALSE;
	END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
    <Property Name="Name" Id="{34c0fc61-f2f3-4510-aa21-6e7de308a6d2}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY Name : T_MaxString]]></Declaration>
      <Get Name="Get" Id="{b36d2889-dbf5-4307-bc29-88bfde6a6b0a}">
        <Declaration><![CDATA[VAR
END_VAR]]></Declaration>
        <Implementation>
          <ST><![CDATA[Name := _Name;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{48fdb33f-6030-41eb-a266-3d231f9f5318}">
        <Declaration><![CDATA[VAR
END_VAR]]></Declaration>
        <Implementation>
          <ST><![CDATA[_Name := Name;]]></ST>
        </Implementation>
      </Set>
    </Property>
