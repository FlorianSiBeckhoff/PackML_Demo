  <POU Name="PackMLModule" Id="{25a20bd0-0f0a-4e0a-b97f-d7939b271cdf}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK ABSTRACT PackMLModule IMPLEMENTS I_PackML_Module
VAR
    // PackML States
    StateMachine : FB_PMLStateMachine;
	StateCommand : E_PMLCommand;
	_CurrentState : E_PMLState;
    
    // PackML Mode
	_CurrentMode : DINT;
	ModeManager : FB_PMLUnitModeManager;
	ModeCommand : DINT;
    
	SequenceState : UDINT;
    _Name : T_MaxString;
END_VAR

VAR CONSTANT
    CLEARING_TIMEOUT : TIME :=  T#5S;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
