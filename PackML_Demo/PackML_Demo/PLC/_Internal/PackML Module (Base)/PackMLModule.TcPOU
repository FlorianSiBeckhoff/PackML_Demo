    </Method>
    <Method Name="ChangeMode" Id="{10147835-b146-4d2c-8a4b-4e05fcf0eafd}" FolderPath="Mode\">
      <Declaration><![CDATA[METHOD ChangeMode
VAR_INPUT
	RequestedMode : DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF RequestedMode <= 0 OR RequestedMode > 31 THEN
	Trace.LogMessage('PackML Mode Controller', ' - Requested Mode is not valid 1..31');
	RETURN;
END_IF

ModeCommand := RequestedMode;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ChangeState" Id="{41ddad9d-1d05-4f86-a234-6efc14f9c8e6}" FolderPath="State Command\">
      <Declaration><![CDATA[METHOD ChangeState
VAR_INPUT
	StateCommand : E_PMLCommand;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF StateCommand <= 0 OR StateCommand > 17 THEN
	Trace.LogMessage('PackML Statemachine ChangeState()', 'StateId is not a PackML State');
END_IF

{warning disable C0196}
THIS^.StateCommand := StateCommand;]]></ST>
      </Implementation>
    </Method>
